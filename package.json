{
  "name": "@twelvehart/orca-ts",
  "version": "0.2.0",
  "description": "TypeScript-native reimagining of Orca: deterministic coding-agent flows with author-time type feedback.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Ahmad Ragab",
  "homepage": "https://github.com/ASRagab/orca-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASRagab/orca-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ASRagab/orca-ts/issues"
  },
  "bin": {
    "orca": "./bin/orca"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "bin/orca",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src/**/*.ts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./loop": {
      "types": "./dist/loop/index.d.ts",
      "default": "./src/loop/index.ts"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "default": "./src/model/index.ts"
    },
    "./testing": {
      "types": "./dist/test-utils/index.d.ts",
      "default": "./src/test-utils/index.ts"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "scripts": {
    "build": "bun build src/cli/main.ts --target bun --outfile dist/orca",
    "build:binary": "bun build src/cli/main.ts --compile --outfile dist/orca",
    "build:types": "tsc -p tsconfig.build.json",
    "build:release": "bun run scripts/build-release-binaries.ts",
    "lint": "eslint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "docs:site:dev": "cd website && bun run dev",
    "docs:site:build": "cd website && bun install --frozen-lockfile && bun run build",
    "docs:site:preview": "cd website && bun run preview",
    "docs:check": "bun run scripts/check-doc-links.ts",
    "docs:symbols": "bun run scripts/check-doc-symbols.ts",
    "docs:signatures": "bun run scripts/check-doc-signatures.ts",
    "check:facade-gate": "bun run scripts/check-facade-gate.ts",
    "test:integration:real": "ORCA_REAL_BACKEND_SMOKE=1 bun test tests/integration/real-backend-smoke.test.ts",
    "validate:fixtures": "bun run scripts/validate-fixtures.ts && bun run scripts/validate-adr-matrix.ts",
    "validate:release": "bun run scripts/validate-release.ts",
    "validate:package": "bun run build:types && bun run scripts/validate-package-artifact.ts",
    "smoke:package": "bun run scripts/smoke-package.ts",
    "smoke:binary": "bun run scripts/smoke-binary.ts",
    "verify": "bun run typecheck && bun test && bun run docs:site:build && bun run docs:check && bun run docs:symbols && bun run validate:fixtures && bun run validate:release && bun run build:types && bun run docs:signatures && bun run check:facade-gate && bun run smoke:binary"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "neverthrow": "^8.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.3",
    "eslint": "^9.39.1",
    "eslint-plugin-boundaries": "^5.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
