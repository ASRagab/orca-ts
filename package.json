{
  "name": "orca-ts",
  "version": "0.1.0",
  "description": "TypeScript port of Orca: deterministic coding-agent flows with author-time type feedback.",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "author": "Ahmad Ragab",
  "homepage": "https://github.com/ASRagab/orca-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASRagab/orca-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ASRagab/orca-ts/issues"
  },
  "bin": {
    "orca": "./bin/orca"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./model": {
      "default": "./src/model/index.ts"
    },
    "./testing": {
      "default": "./src/test-utils/index.ts"
    }
  },
  "scripts": {
    "build": "bun build src/cli/main.ts --target bun --outfile dist/orca",
    "build:binary": "bun build src/cli/main.ts --compile --outfile dist/orca",
    "build:types": "tsc -p tsconfig.build.json",
    "build:release": "bun run scripts/build-release-binaries.ts",
    "lint": "eslint .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "docs:check": "bun run scripts/check-doc-links.ts",
    "test:integration:real": "ORCA_REAL_BACKEND_SMOKE=1 bun test tests/integration/real-backend-smoke.test.ts",
    "validate:fixtures": "bun run scripts/validate-fixtures.ts && bun run scripts/validate-adr-matrix.ts",
    "validate:release": "bun run scripts/validate-release.ts",
    "smoke:binary": "bun run scripts/smoke-binary.ts",
    "verify": "bun run typecheck && bun test && bun run docs:check && bun run validate:fixtures && bun run validate:release && bun run build:types && bun run smoke:binary"
  },
  "dependencies": {
    "neverthrow": "^8.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.3",
    "eslint": "^9.39.1",
    "eslint-plugin-boundaries": "^5.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
